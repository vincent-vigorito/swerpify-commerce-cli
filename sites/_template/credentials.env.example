# Credenziali di UN sito SwerpiCommerce. Copia questa cartella-template con il nome
# del sito (es. `cp -r _template gevi`) e compila i 3 valori qui sotto.
# api_id/api_secret sono la "chiave madre": il wrapper `swc` le usa per rigenerare
# da solo il token Bearer (POST /auth/token). NON committare mai questo file.

SWERPICOMMERCE_API_ID=
SWERPICOMMERCE_API_SECRET=
SWERPICOMMERCE_BASE_URL=https://<TENANT>.swebbysites.com/api/v2
